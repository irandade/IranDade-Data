{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "measurement_unit.schema.json",
  "title": "Measurement Unit",
  "description": "Definition of a measurement unit — its type, coefficient, and optional currency",
  "type": "object",
  "properties": {
    "measurement_unit_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Name of the measure"
    },
    "alt_name": {
      "type": "string",
      "maxLength": 255,
      "description": "Alternative name / abbreviation"
    },
    "unit_coefficient": {
      "type": "integer",
      "default": 1,
      "description": "Multiplier for unit conversion (e.g. 1000 for thousands)"
    },
    "unit_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["MTR", "UNT", "MT2", "PRS", "IIR", "USD", "PCT", "IXP"],
      "description": "Unit type: MTR=Meter, UNT=Unit, MT2=Square Meter, PRS=Person, IIR=Iranian Rial, USD=US Dollar, PCT=Percent, IXP=Index Point"
    },
    "base_year": {
      "type": "integer",
      "description": "Base year for index-based measures"
    },
    "description": {
      "type": "string",
      "description": "Description of the measure"
    },
    "currency_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["IIR", "USD"],
      "description": "Currency type: IIR=Iranian Rial, USD=US Dollar"
    }
  },
  "required": [
    "measurement_unit_uid",
    "name",
    "alt_name",
    "unit_type"
  ],
  "additionalProperties": false
}
