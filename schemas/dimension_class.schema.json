{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "dimension_class.schema.json",
  "title": "Dimension Class",
  "description": "A category of dimension values (e.g. Gender, Location Type, Age Group)",
  "type": "object",
  "properties": {
    "dimension_class_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Name of this dimension kind"
    },
    "alt_name1": {
      "type": "string",
      "maxLength": 255,
      "description": "Alternative name"
    },
    "alt_name2": {
      "type": "string",
      "maxLength": 255,
      "description": "Alternative name"
    },
    "alt_name3": {
      "type": "string",
      "maxLength": 255,
      "description": "Alternative name"
    },
    "description": {
      "type": "string",
      "description": "Description of this dimension class"
    }
  },
  "required": [
    "dimension_class_uid",
    "name",
    "alt_name1",
    "alt_name2",
    "alt_name3"
  ],
  "additionalProperties": false
}
