{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "publisher.schema.json",
  "title": "Publisher",
  "description": "An organization that publishes data documents or datasets",
  "type": "object",
  "properties": {
    "publisher_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Publisher name"
    },
    "description": {
      "type": "string",
      "description": "Description of the publisher"
    },
    "is_domestic": {
      "type": "boolean",
      "default": true,
      "description": "Whether the publisher is domestic (Iranian) or foreign"
    },
    "website": {
      "type": "string",
      "maxLength": 255,
      "description": "Publisher website URL"
    }
  },
  "required": [
    "publisher_uid",
    "name"
  ],
  "additionalProperties": false
}
