{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "indicator.schema.json",
  "title": "Indicator",
  "description": "An economic or statistical indicator — a named set of observations (e.g. 'CPI', 'GDP Growth')",
  "type": "object",
  "properties": {
    "indicator_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Name of the indicator"
    },
    "description": {
      "type": "string",
      "description": "Description of the indicator"
    },
    "concept_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to concept this indicator belongs to"
    }
  },
  "required": [
    "indicator_uid",
    "name"
  ],
  "additionalProperties": false
}
