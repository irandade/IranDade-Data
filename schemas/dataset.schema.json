{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "dataset.schema.json",
  "title": "Dataset",
  "description": "A named collection of data documents, published by a publisher",
  "type": "object",
  "properties": {
    "dataset_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Dataset name"
    },
    "description": {
      "type": "string",
      "description": "Description of the dataset"
    },
    "url": {
      "type": "string",
      "maxLength": 2048,
      "description": "Dataset URL"
    },
    "publisher_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to publisher"
    }
  },
  "required": [
    "dataset_uid",
    "name",
    "publisher_uid"
  ],
  "additionalProperties": false
}
