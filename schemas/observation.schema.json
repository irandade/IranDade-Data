{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "observation.schema.json",
  "title": "Observation",
  "description": "A single data point — a numeric value for a series at a point in time and place",
  "type": "object",
  "properties": {
    "observation_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "value": {
      "type": "number",
      "description": "Numeric value of the observation"
    },
    "series_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to series this observation belongs to"
    },
    "observation_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["OBS", "EST"],
      "description": "Observation type: OBS=Observed, EST=Estimated"
    },
    "formality_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["FRM", "SFM", "INF", "MIX"],
      "description": "Formality type: FRM=Formal, SFM=Semiformal, INF=Informal, MIX=Mixed"
    },
    "review_status_type": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["DSC", "REV"],
      "description": "Review status: DSC=Discovered, REV=Reviewed"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the observation was published"
    },
    "geography_dimension_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to geography_dimension (location context)"
    },
    "time_dimension_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to time_dimension (time context)"
    },
    "source_document_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to source_document (source provenance)"
    }
  },
  "required": [
    "observation_uid",
    "series_uid",
    "observation_type",
    "formality_type",
    "review_status_type"
  ],
  "additionalProperties": false
}
