{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://irandade.ir/schemas/metadata_package.schema.json",
  "title": "Metadata Package",
  "description": "JSON schema for saving metadata package data (GeographyDimension, TimeDimension, DayDimension, DimCategory, Dimension, Measure). Each top-level array holds records to insert into the corresponding table. Primary keys are optional — server auto-generates UUID v7 if omitted.",
  "type": "object",
  "properties": {
    "geography_dimensions": {
      "type": "array",
      "description": "Geography hierarchy entries (continent, country, state, county, city)",
      "items": {
        "$ref": "#/$defs/GeographyDimension"
      }
    },
    "time_dimensions": {
      "type": "array",
      "description": "Time hierarchy entries (century, year, month, quarter, week, day)",
      "items": {
        "$ref": "#/$defs/TimeDimension"
      }
    },
    "day_dimensions": {
      "type": "array",
      "description": "Day dimension entries with Gregorian, Jalali, and Lunar calendar mappings",
      "items": {
        "$ref": "#/$defs/DayDimension"
      }
    },
    "dim_categories": {
      "type": "array",
      "description": "Dimension category entries for grouping dimensions",
      "items": {
        "$ref": "#/$defs/DimCategory"
      }
    },
    "dimensions": {
      "type": "array",
      "description": "Dimension entries",
      "items": {
        "$ref": "#/$defs/Dimension"
      }
    },
    "dim_category_dimension_rels": {
      "type": "array",
      "description": "Many-to-many relationships between dimensions and dimension categories",
      "items": {
        "$ref": "#/$defs/DimCategoryDimensionRel"
      }
    },
    "measures": {
      "type": "array",
      "description": "Measure entries (metrics/indicators)",
      "items": {
        "$ref": "#/$defs/Measure"
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "geography_dimensions"
      ]
    },
    {
      "required": [
        "time_dimensions"
      ]
    },
    {
      "required": [
        "day_dimensions"
      ]
    },
    {
      "required": [
        "dim_categories"
      ]
    },
    {
      "required": [
        "dimensions"
      ]
    },
    {
      "required": [
        "dim_category_dimension_rels"
      ]
    },
    {
      "required": [
        "measures"
      ]
    }
  ],
  "$defs": {
    "GeographyDimType": {
      "type": "string",
      "description": "Geography dimension level type",
      "enum": [
        "CON",
        "COU",
        "STA",
        "CTY",
        "CIT"
      ]
    },
    "GeographyStateType": {
      "type": "string",
      "description": "Geography state sub-type for STATE-level entries",
      "enum": [
        "STT",
        "PRO",
        "TER"
      ]
    },
    "CalendarType": {
      "type": "string",
      "description": "Calendar system",
      "enum": [
        "LUN",
        "GRG",
        "JAL"
      ]
    },
    "TimeDimensionType": {
      "type": "string",
      "description": "Time dimension granularity level",
      "enum": [
        "CEN",
        "YEA",
        "MON",
        "QRT",
        "WEE",
        "DAY"
      ]
    },
    "ValueType": {
      "type": "string",
      "description": "Measurement value storage type",
      "enum": ["DEC", "FLT"]
    },
    "CurrencyType": {
      "type": "string",
      "description": "Currency type",
      "enum": ["IIR", "USD"]
    },
    "GeographyDimension": {
      "type": "object",
      "description": "A location entry in the geography hierarchy (e.g. continent, country, state, county, city)",
      "properties": {
        "geography_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "name_fa": {
          "type": "string",
          "maxLength": 255,
          "description": "Persian name"
        },
        "name_en": {
          "type": "string",
          "maxLength": 255,
          "description": "English name"
        },
        "description_fa": {
          "type": "string",
          "description": "Persian description"
        },
        "description_en": {
          "type": "string",
          "description": "English description"
        },
        "valid_start_at": {
          "type": "string",
          "format": "date-time",
          "description": "Start of validity period (ISO 8601)"
        },
        "valid_end_at": {
          "type": "string",
          "format": "date-time",
          "description": "End of validity period (ISO 8601)"
        },
        "geography_dim_type_code": {
          "$ref": "#/$defs/GeographyDimType",
          "description": "Level in the geography hierarchy"
        },
        "state_type_code": {
          "$ref": "#/$defs/GeographyStateType",
          "description": "Sub-type for STATE-level entries (state/province/territory)"
        },
        "parent_geography_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "Parent geography entry for hierarchical nesting"
        }
      },
      "required": [
        "created_by",
        "name_fa",
        "name_en",
        "geography_dim_type_code"
      ],
      "additionalProperties": false
    },
    "TimeDimension": {
      "type": "object",
      "description": "A time period entry in the calendar hierarchy (e.g. year 1403, month 6, day 15)",
      "properties": {
        "time_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "name": {
          "type": "string",
          "maxLength": 255,
          "description": "Human-readable name for this time period"
        },
        "after_origin": {
          "type": "boolean",
          "default": true,
          "description": "Whether this period is after the calendar origin (CE/AD or after Hijrah)"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "century_value": {
          "type": "integer",
          "description": "Century number"
        },
        "year_value": {
          "type": "integer",
          "description": "Year number"
        },
        "month_value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Month number (1–12)"
        },
        "day_value": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31,
          "description": "Day number (1–31)"
        },
        "day_of_week_value": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6,
          "description": "Day of week (0=Saturday, 6=Friday in Jalali; 0=Monday, 6=Sunday in Gregorian)"
        },
        "date_value": {
          "type": "string",
          "format": "date",
          "description": "Full date value (ISO 8601, e.g. 2026-06-01)"
        },
        "datetime_value": {
          "type": "string",
          "format": "date-time",
          "description": "Full timestamp with timezone (ISO 8601)"
        },
        "calendar_type_code": {
          "$ref": "#/$defs/CalendarType",
          "description": "Calendar system this entry belongs to"
        },
        "time_dimension_type_code": {
          "$ref": "#/$defs/TimeDimensionType",
          "description": "Granularity level of this time period"
        },
        "parent_time_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "Parent time entry for hierarchical nesting (e.g. month parent is year)"
        }
      },
      "required": [
        "created_by",
        "name",
        "after_origin",
        "calendar_type_code",
        "time_dimension_type_code"
      ],
      "additionalProperties": false
    },
    "DayDimension": {
      "type": "object",
      "description": "A day dimension entry with Gregorian, Jalali, and Lunar calendar mappings",
      "properties": {
        "day_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "grg_name": {
          "type": "string",
          "maxLength": 255,
          "description": "Gregorian calendar day name"
        },
        "jal_name": {
          "type": "string",
          "maxLength": 255,
          "description": "Jalali calendar day name"
        },
        "lun_name": {
          "type": "string",
          "maxLength": 255,
          "description": "Lunar calendar day name"
        },
        "grg_century": {
          "type": "integer",
          "description": "Gregorian century"
        },
        "grg_year": {
          "type": "integer",
          "description": "Gregorian year"
        },
        "grg_month": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Gregorian month (1–12)"
        },
        "grg_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31,
          "description": "Gregorian day (1–31)"
        },
        "grg_day_of_week": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6,
          "description": "Gregorian day of week (0=Monday, 6=Sunday)"
        },
        "jal_century": {
          "type": "integer",
          "description": "Jalali century"
        },
        "jal_year": {
          "type": "integer",
          "description": "Jalali year"
        },
        "jal_month": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12,
          "description": "Jalali month (1–12)"
        },
        "jal_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31,
          "description": "Jalali day (1–31)"
        },
        "jal_day_of_week": {
          "type": "integer",
          "minimum": 0,
          "maximum": 6,
          "description": "Jalali day of week (0=Saturday, 6=Friday)"
        },
        "date_value": {
          "type": "string",
          "format": "date",
          "description": "Full date value (ISO 8601)"
        },
        "grg_month_uid": {
          "type": "string",
          "format": "uuid",
          "description": "FK to the Gregorian month time_dimension entry"
        },
        "jal_month_uid": {
          "type": "string",
          "format": "uuid",
          "description": "FK to the Jalali month time_dimension entry"
        }
      },
      "required": [
        "created_by",
        "grg_name"
      ],
      "additionalProperties": false
    },
    "DimCategory": {
      "type": "object",
      "description": "A category for grouping dimensions (e.g. Economic Sector, Industry branch)",
      "properties": {
        "dim_category_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "name": {
          "type": "string",
          "maxLength": 255,
          "description": "Name of the dimension category"
        },
        "alt_name1": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 1"
        },
        "alt_name2": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 2"
        },
        "alt_name3": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 3"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "parent_dim_category_uid": {
          "type": "string",
          "format": "uuid",
          "description": "Parent category for hierarchical nesting"
        }
      },
      "required": [
        "created_by",
        "name",
        "alt_name1",
        "alt_name2",
        "alt_name3"
      ],
      "additionalProperties": false
    },
    "Dimension": {
      "type": "object",
      "description": "A dimension instance (e.g. Sector: Agriculture, Industry: Automotive)",
      "properties": {
        "dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "name": {
          "type": "string",
          "maxLength": 255,
          "description": "Name of the dimension"
        },
        "alt_name1": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 1"
        },
        "alt_name2": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 2"
        },
        "alt_name3": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name variation 3"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "measure_uid": {
          "type": "string",
          "format": "uuid",
          "description": "Optional FK to measure — primary metric for this dimension"
        },
        "parent_dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "Parent dimension for hierarchical nesting"
        }
      },
      "required": [
        "created_by",
        "name",
        "alt_name1",
        "alt_name2",
        "alt_name3"
      ],
      "additionalProperties": false
    },
    "DimCategoryDimensionRel": {
      "type": "object",
      "description": "Many-to-many relationship linking a dimension to a dimension category",
      "properties": {
        "dimension_uid": {
          "type": "string",
          "format": "uuid",
          "description": "FK to the dimension"
        },
        "dim_category_uid": {
          "type": "string",
          "format": "uuid",
          "description": "FK to the dimension category"
        }
      },
      "required": [
        "dimension_uid",
        "dim_category_uid"
      ],
      "additionalProperties": false
    },
    "Measure": {
      "type": "object",
      "description": "A measure/metric/indicator definition",
      "properties": {
        "measure_uid": {
          "type": "string",
          "format": "uuid",
          "description": "UUID v7 primary key — auto-generated if omitted"
        },
        "created_by": {
          "type": "string",
          "maxLength": 255,
          "description": "Audit field identifying who created this record"
        },
        "name": {
          "type": "string",
          "maxLength": 255,
          "description": "Name of the measure"
        },
        "alt_name": {
          "type": "string",
          "maxLength": 255,
          "description": "Alternate name for the measure"
        },
        "unit": {
          "type": "string",
          "maxLength": 50,
          "description": "Unit of measurement (e.g. PERCENT, M, M2, PERSON, CURRENCY)"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "value_type_code": {
          "$ref": "#/$defs/ValueType",
          "description": "Value storage type (DECIMAL or FLOAT)"
        },
        "currency_type_code": {
          "$ref": "#/$defs/CurrencyType",
          "description": "Currency type for monetary measures"
        },
        "coefficient": {
          "type": "integer",
          "description": "Coefficient for scaling the measure value"
        }
      },
      "required": [
        "created_by",
        "name",
        "alt_name",
        "value_type_code"
      ],
      "additionalProperties": false
    }
  }
}
