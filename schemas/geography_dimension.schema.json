{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "geography_dimension.schema.json",
  "title": "Geography Dimension",
  "description": "Geographic hierarchy: continents, countries, states/provinces, counties, cities",
  "type": "object",
  "properties": {
    "geography_dimension_uid": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v7 primary key"
    },
    "created_by": {
      "type": "string",
      "maxLength": 255,
      "default": "system",
      "description": "Who created this record"
    },
    "name_fa": {
      "type": "string",
      "maxLength": 255,
      "description": "Name in Persian/Farsi"
    },
    "name_en": {
      "type": "string",
      "maxLength": 255,
      "description": "Name in English"
    },
    "description_fa": {
      "type": "string",
      "description": "Description in Persian/Farsi"
    },
    "description_en": {
      "type": "string",
      "description": "Description in English"
    },
    "code": {
      "type": "string",
      "maxLength": 255,
      "description": "Geographic code (e.g. ISO code, national code)"
    },
    "valid_start_at": {
      "type": "string",
      "format": "date-time",
      "description": "Start of validity period"
    },
    "valid_end_at": {
      "type": "string",
      "format": "date-time",
      "description": "End of validity period"
    },
    "geography_dim_type_code": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["CON", "COU", "STA", "CTY", "CIT"],
      "description": "Geography dimension type: CON=Continent, COU=Country, STA=State/Province, CTY=County, CIT=City"
    },
    "state_type_code": {
      "type": "string",
      "minLength": 3,
      "maxLength": 3,
      "enum": ["PRO", "TRI", "STA"],
      "description": "State type: PRO=Province, TRI=Territory, STA=State"
    },
    "parent_geography_dimension_uid": {
      "type": "string",
      "format": "uuid",
      "description": "FK to parent geography_dimension (self-referencing hierarchy)"
    }
  },
  "required": [
    "geography_dimension_uid",
    "name_fa",
    "name_en",
    "geography_dim_type_code"
  ],
  "additionalProperties": false
}
